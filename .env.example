# ======================
# SERVER CONFIGURATION
# ======================
PORT=1000
NODE_ENV=development

# ======================
# DATABASE
# ======================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ======================
# SECURITY - JWT
# ======================
# IMPORTANT: Use a strong random string (at least 32 characters)
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random_at_least_32_chars
JWT_EXPIRY=7d

# ======================
# SECURITY - CORS
# ======================
# Comma-separated list of allowed origins (no spaces)
# Example: https://example.com,https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ======================
# EMAIL CONFIGURATION (SMTP)
# ======================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=YourAppName

# ======================
# FRONTEND URL
# ======================
FRONTEND_URL=http://localhost:3000

# ======================
# THIRD-PARTY API KEYS
# ======================

# Wise API
WISE_API_KEY=your_wise_api_key
WISE_API_BASE=https://api.sandbox.transferwise.tech/v1

# Revolut API
REVOLUT_CLIENT_ID=your_revolut_client_id
REVOLUT_ENV=sandbox
REVOLUT_REDIRECT_DOMAIN=https://yourdomain.com

# Trustpilot API (via RapidAPI)
TRUSTPILOT_RAPIDAPI_KEY=your_rapidapi_key_here
